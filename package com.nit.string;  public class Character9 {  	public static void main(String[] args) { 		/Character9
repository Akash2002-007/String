package com.nit.string;

public class Character9 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        String str="program";
         char key='a';
         int count=0;
         
         for(int i=0;i<str.length();i++) {
        	    char ch=str.charAt(i);
        	 if(ch==key) {
        		 count++;
        	 }
        
	}
         System.out.println(count);     
	}

}
